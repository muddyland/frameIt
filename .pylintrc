[MASTER]
# Add the project root so pylint can resolve local imports
init-hook='import sys; sys.path.insert(0, ".")'

[MESSAGES CONTROL]
disable =
    # SQLAlchemy column attributes are dynamically generated — pylint cannot
    # see them at static analysis time.
    no-member,

    # Model classes intentionally have no public methods beyond to_dict().
    too-few-public-methods,

    # Flask route functions are called by the framework, not directly.
    # Unused import warnings for 'app' re-exports are noise.
    unused-import,

    # Standard Flask pattern: import-outside-toplevel in app factories.
    import-outside-toplevel,

    # We use subprocess intentionally for system control.
    subprocess-run-check,

    # Docstrings are not required for Flask route functions or simple models.
    missing-module-docstring,
    missing-function-docstring,
    missing-class-docstring,

    # Flask defines a route function named 'frame'; local variables named
    # 'frame' in other routes shadow it — this is intentional and harmless.
    redefined-outer-name,

    # Agent uses a module-level mutable variable (not a true constant).
    invalid-name,

    # Agent and server catch broad exceptions intentionally for resilience —
    # network and subprocess errors can come in many forms.
    broad-exception-caught,

    # Agent uses 'global _frame_id' to update registration state from a thread.
    global-statement

[FORMAT]
max-line-length = 120

[DESIGN]
# Agent and main.py have many routes — relax these limits.
max-args = 8
max-attributes = 12
max-public-methods = 30

[SIMILARITIES]
# Flask route boilerplate looks similar but is intentional.
min-similarity-lines = 8
ignore-imports = yes

[TYPECHECK]
# SQLAlchemy and Flask-SQLAlchemy generate attributes dynamically.
ignored-modules = sqlalchemy, flask_sqlalchemy
ignored-classes = SQLAlchemy, scoped_session
